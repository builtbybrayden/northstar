# Northstar server config — copy to .env and fill in
NORTHSTAR_LISTEN_ADDR=:8080
NORTHSTAR_DB_PATH=./data/northstar.db
NORTHSTAR_LOG_LEVEL=info

# Pairing code TTL in seconds (default 600 = 10 minutes)
NORTHSTAR_PAIRING_TTL=600

# Admin token gating POST /api/pair/initiate. When unset the endpoint is open
# (server logs a warning) — fine on a Tailnet/LAN, risky if ever exposed.
# Generate with:  openssl rand -hex 32
NORTHSTAR_ADMIN_TOKEN=

# Pillar enables (1=on, 0=off)
NORTHSTAR_PILLAR_FINANCE=1
NORTHSTAR_PILLAR_GOALS=1
NORTHSTAR_PILLAR_HEALTH=1
NORTHSTAR_PILLAR_AI=1

# Finance sync (Phase 1)
NORTHSTAR_FINANCE_SIDECAR_URL=http://127.0.0.1:9090
NORTHSTAR_FINANCE_SIDECAR_SECRET=
NORTHSTAR_FINANCE_SYNC_SECONDS=900
NORTHSTAR_FINANCE_SYNC_ENABLED=1

# Finance provider mode:
#   mock   = sidecar serves baked-in fixtures (default, no creds needed)
#   actual = sidecar connects to a real Actual Budget server using the
#            credentials below; server forwards them via POST /init at boot
NORTHSTAR_FINANCE_MODE=mock

# Actual Budget connection (only used when NORTHSTAR_FINANCE_MODE=actual).
# From inside a Docker container `localhost` is the container itself, so
# point at host.docker.internal (Windows/Mac) when Actual runs on the host.
NORTHSTAR_ACTUAL_SERVER_URL=
NORTHSTAR_ACTUAL_PASSWORD=
NORTHSTAR_ACTUAL_SYNC_ID=
NORTHSTAR_ACTUAL_ENCRYPTION_PASSWORD=

# WHOOP OAuth (only used when WHOOP sidecar runs in real mode)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=

# Phase 5 AI (Ask Claude)
NORTHSTAR_AI_MODE=mock                 # mock | anthropic | cli
NORTHSTAR_CLAUDE_API_KEY=
NORTHSTAR_AI_MODEL=claude-sonnet-4-6
NORTHSTAR_CLI_BIN=claude
# Optional: when the server runs in Docker, it can't reach the host's
# `claude` binary via exec. Point at a host-side bridge instead (run
# `node tools/claude-cli-bridge/src/server.js` on the host). When this is
# set, the server uses the HTTP path; when empty, it falls back to exec.
NORTHSTAR_CLI_BRIDGE_URL=
NORTHSTAR_CLI_BRIDGE_SECRET=

# Litestream (used by compose, not the server binary)
LITESTREAM_B2_BUCKET=
LITESTREAM_B2_ACCESS_KEY_ID=
LITESTREAM_B2_SECRET_ACCESS_KEY=
